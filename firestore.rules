rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the current user is an admin
    // This requires adding the user's UID as a document in an 'admins' collection
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /vehicles/{vehicleId} {
      // Anyone can view the inventory
      allow read: if true;
      // Only admins can modify the inventory
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      // Storefront settings need to be readable by the public site
      allow read: if true;
      // Only admins can update settings
      allow write: if isAdmin();
    }

    // Explicitly deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
